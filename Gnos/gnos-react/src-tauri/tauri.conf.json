{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gnos",
  "version": "0.1.0",
  "identifier": "com.gnos.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": " ",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["epub"], "name": "EPUB Document" },
      { "ext": ["txt"],  "name": "Text Document" },
      { "ext": ["md"],   "name": "Markdown Document" },
      { "ext": ["pdf"],  "name": "PDF Document" },
      { "ext": ["mp3"],  "name": "MP3 Audio" },
      { "ext": ["m4b"],  "name": "M4B Audiobook" }
    ]
  }
}
